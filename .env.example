# ===========================================
# 4ourMedia PromoGen - Environment Variables
# ===========================================

# Mode (set to 'true' for demo site)
DEMO_MODE=true

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe Configuration (for payments)
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_AGENCY=price_xxx
STRIPE_PRICE_UNLIMITED=price_xxx

# ===========================================
# API SAFETY & RATE LIMITING
# ===========================================

# Kill switch - set to 'true' to immediately disable all AI API calls
# Use this in emergencies (runaway costs, abuse, etc.)
API_KILL_SWITCH=false

# Global limits (per time period)
API_MONTHLY_LIMIT=10000    # Max total API calls per month
API_DAILY_LIMIT=500        # Max total API calls per day

# Rate limits (per entity per minute)
IP_RATE_LIMIT=10           # Max requests per IP per minute
USER_RATE_LIMIT=20         # Max requests per authenticated user per minute

# Strict CORS - set to 'true' to only allow 4ourmedia.com
# Leave 'false' during development
STRICT_CORS=false

# Admin access for /api/admin/stats
# Require both:
# 1. ADMIN_SECRET entered in the dashboard
# 2. A signed-in Supabase user whose email or user id is allowlisted below
ADMIN_SECRET=your_secure_random_string_here
ADMIN_EMAILS=owner@example.com
# ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000
